# Copy this file to .env.local and fill in your values.

# --- Demo mode (leave as-is for local development) ---
NEXT_PUBLIC_DEMO_MODE=true
APP_ENV=development

# --- Default map center (San Francisco) ---
NEXT_PUBLIC_DEFAULT_LAT=37.7749
NEXT_PUBLIC_DEFAULT_LNG=-122.4194
NEXT_PUBLIC_DEFAULT_CITY=CivicSignal Bay Demo

# --- Groq API (free) — required for AI image analysis ---
# Sign up at https://console.groq.com, create an API key, paste it here.
GROQ_API_KEY=gsk_your_key_here

# --- Optional: OpenAI (for report text analysis) ---
# OPENAI_API_KEY=sk_your_key_here

# --- Optional: Map tiles (leave blank to use fallback) ---
# NEXT_PUBLIC_MAP_STYLE_URL=

# --- Optional: Geocoding ---
# GEOCODING_PROVIDER=
# GEOCODING_API_KEY=
