# Copy this file to .env.local and fill in your values.

# --- Demo mode (leave as-is for local development) ---
NEXT_PUBLIC_DEMO_MODE=true
APP_ENV=development

# --- Default map center (San Francisco) ---
NEXT_PUBLIC_DEFAULT_LAT=37.7749
NEXT_PUBLIC_DEFAULT_LNG=-122.4194
NEXT_PUBLIC_DEFAULT_CITY=CivicSignal Bay Demo

# --- Optional: Gemini AI ---
# Use .env.local for real keys. Do not commit secrets.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Optional: Public feed contact header ---
CIVICSIGNAL_CONTACT=

# --- Optional: Scheduler auth ---
# If blank, demo admins can still trigger /api/cron/* from the UI.
CRON_SECRET=

# --- Optional: Map tiles (leave blank to use fallback) ---
# NEXT_PUBLIC_MAP_STYLE_URL=
# NEXT_PUBLIC_SATELLITE_TILE_URL=
# NEXT_PUBLIC_TERRAIN_TILE_URL=

# --- Optional: Geocoding ---
# GEOCODING_PROVIDER=
# GEOCODING_API_KEY=
